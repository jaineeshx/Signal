# ============================================================
# SIGNAL — .gitignore
# ============================================================

# --- Python ---
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
*.egg
.eggs/

# --- Virtual environments ---
env/
venv/
.venv/
ENV/

# --- Environment & secrets ---
.env
*.env.local

# --- Testing & coverage ---
.pytest_cache/
.coverage
htmlcov/
*.coveragerc
.tox/

# --- IDEs ---
.vscode/
.idea/
*.swp
*.swo
*~

# --- OS files ---
.DS_Store
Thumbs.db
desktop.ini

# --- Logs ---
*.log
logs/

# --- Distribution ---
*.whl
*.tar.gz
